# Beam Me Up - environment variables
#
# The MCP server itself needs NO secrets to run. The provider tokens below are
# read lazily — only when a deploy/DB tool actually calls that provider. Copy to
# .env and fill in what you need.

# ---- HTTP transport (the "MCP API"): host + port ----
# Port for `npm run dev:http` / `npm run start:http`.
PORT=3000
# The server binds 127.0.0.1 (loopback) by default. Set a host to expose it
# (e.g. 0.0.0.0 in a container) — but it then REFUSES to start without OAuth
# unless BEAM_HTTP_ALLOW_INSECURE=1 (see below).
# BEAM_HTTP_HOST=127.0.0.1
# Comma-separated Host / Origin allowlists for DNS-rebinding protection when you
# put it behind a domain (loopback is always allowed; Origin is only enforced
# when the request carries one).
# BEAM_HTTP_ALLOWED_HOSTS=mcp.yourco.com
# BEAM_HTTP_ALLOWED_ORIGINS=https://app.yourco.com
# Escape hatch: allow a no-auth server on a non-loopback host (trusted private
# network only). Leave UNSET in any real deployment.
# BEAM_HTTP_ALLOW_INSECURE=

# ---- Vercel deploys (real network, only when a deploy tool is called) ----
# Create a token at https://vercel.com/account/tokens. VERCEL_TEAM_ID is only
# needed for projects that live under a Vercel Team.
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=

# ---- DigitalOcean App Platform deploys (real network, only when a deploy tool is called) ----
# Create a token at https://cloud.digitalocean.com/account/api/tokens
# DIGITALOCEAN_TOKEN=

# ---- Database provisioning (real network, only when provision_database is called) ----
# postgres -> Neon. Create an API key at https://console.neon.tech/app/settings/api-keys
# NEON_API_KEY=
# redis -> Upstash. Find your email + API key at https://console.upstash.com/account/api
# UPSTASH_EMAIL=
# UPSTASH_API_KEY=

# ---- OAuth on the HTTP transport (the server is an OAuth 2.0 Resource Server) ----
# Set ALL of: OAUTH_ISSUER + OAUTH_AUDIENCE + one key (OAUTH_JWT_SECRET for HS256
# or OAUTH_JWT_PUBLIC_KEY for RS256) to require a verified bearer token on /mcp.
# When unset, /mcp runs no-auth (loopback only). These are NOT OAuth-client
# (CLIENT_ID/SECRET) values — this server verifies tokens, it does not issue them.
# OAUTH_ISSUER=https://your-auth-server.example.com
# OAUTH_AUDIENCE=beam-me-up
# OAUTH_JWT_SECRET=                 # HS256 shared secret, OR an RS256 key below:
# OAUTH_JWT_PUBLIC_KEY=             # RS256 static PEM public key, OR:
# OAUTH_JWKS_URI=                   # RS256 via JWKS — the AS's JWKS URL. Preferred
#                                   # for a managed IdP whose signing key rotates
#                                   # (keys are fetched + cached by `kid`).
# OAUTH_JWT_ALG=                    # optional: HS256 (default) | RS256
# OAUTH_RESOURCE_URL=http://localhost:3000/mcp   # optional: this resource's URL
# OAUTH_REQUIRED_SCOPES=            # optional: space-separated scopes to require
#
# Hosting it as a public remote connector? Point a managed IdP (e.g. WorkOS
# AuthKit) at this resource and set OAUTH_ISSUER + OAUTH_AUDIENCE + OAUTH_JWKS_URI,
# OAUTH_RESOURCE_URL to the public https URL, BEAM_HTTP_HOST=0.0.0.0, and
# BEAM_HTTP_ALLOWED_HOSTS to the public domain (TLS terminates at a proxy/LB).

# ---- M9 hosted multi-tenant vault (per-user provider credentials) ----
# Only for the HOSTED tier. When BEAM_VAULT_DATABASE_URL is UNSET, the server is
# single-tenant and resolves provider creds from the env vars above (unchanged).
# BEAM_TIER=hosted                  # turns on the hosted guardrails below
# BEAM_VAULT_DATABASE_URL=          # Beam-OWNED Postgres (NOT a user-provisioned DB)
# BEAM_VAULT_PG_SSL=require         # verify the DB cert (supply BEAM_VAULT_PG_CA);
#                                   # "require-insecure" is refused when BEAM_TIER=hosted
# BEAM_VAULT_PG_CA=                 # PEM CA bundle for the managed DB (e.g. the DO CA)
# BEAM_KEK_PROVIDER=aws-kms         # local-dev | aws-kms | gcp-kms (local-dev refused on hosted)
# BEAM_KMS_KEY_ID=                  # KMS key ARN / resource name for the KEK
# BEAM_KEK_LOCAL_SECRET=            # base64 32-byte KEK — DEV/self-host ONLY
# BEAM_CONFIRM_TOKEN_SECRET=        # HMAC secret for the deploy-confirmation gate.
#                                   # REQUIRED on hosted — without it the public dev
#                                   # default could be used to bypass the "Yes, deploy"
#                                   # confirmation (the server refuses to mint otherwise).
