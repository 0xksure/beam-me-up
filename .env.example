# Beam Me Up - environment variables
#
# M0 is fully local and requires NO secrets. The HTTP dev server runs without
# auth. The variables below are placeholders for later milestones.

# ---- HTTP dev server (M0) ----
# Port for `npm run dev:http` / `npm run start:http`.
PORT=3000

# ---- M1: Vercel deploys (real network, only when a deploy tool is called) ----
# Create a token at https://vercel.com/account/tokens. VERCEL_TEAM_ID is only
# needed for projects that live under a Vercel Team.
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=

# ---- M2: database provisioning (real network, only when provision_database is called) ----
# postgres -> Neon. Create an API key at https://console.neon.tech/app/settings/api-keys
# NEON_API_KEY=
# redis -> Upstash. Find your email + API key at https://console.upstash.com/account/api
# UPSTASH_EMAIL=
# UPSTASH_API_KEY=

# ---- Coming later: OAuth on the Streamable HTTP transport ----
# OAUTH_ISSUER_URL=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=

# ---- Coming later: more provider APIs (DigitalOcean, scanners) ----
# DIGITALOCEAN_TOKEN=
