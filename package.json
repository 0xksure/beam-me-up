{
  "name": "beam-me-up",
  "version": "0.0.0",
  "private": true,
  "description": "Beam Me Up MCP server - orchestrates a repo-to-deploy plan via one prompt and three pure tools (M0).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b tsconfig.solution.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev:stdio": "tsx packages/server/src/server/stdio.ts",
    "dev:http": "tsx packages/server/src/server/http.ts",
    "start:stdio": "node packages/server/dist/server/stdio.js",
    "start:http": "node packages/server/dist/server/http.js",
    "test": "tsx packages/server/src/smoke-test.ts",
    "test:m1": "tsx test/m1.test.ts",
    "test:m2": "tsx test/m2.test.ts",
    "test:m3": "tsx test/m3.test.ts",
    "test:m4": "tsx test/m4.test.ts",
    "test:m5": "tsx test/m5.test.ts",
    "test:m7": "tsx test/m7.test.ts",
    "test:m8": "tsx test/m8.test.ts",
    "test:m9": "tsx test/m9.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
