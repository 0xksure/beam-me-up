{
  "name": "beam-me-up",
  "version": "0.0.0",
  "private": true,
  "description": "Beam Me Up MCP server - orchestrates a repo-to-deploy plan via one prompt and three pure tools (M0).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "beam-me-up": "dist/server/stdio.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev:stdio": "tsx src/server/stdio.ts",
    "dev:http": "tsx src/server/http.ts",
    "start:stdio": "node dist/server/stdio.js",
    "start:http": "node dist/server/http.js",
    "test": "tsx src/smoke-test.ts",
    "test:m1": "tsx test/m1.test.ts",
    "test:m2": "tsx test/m2.test.ts",
    "test:m3": "tsx test/m3.test.ts",
    "test:m4": "tsx test/m4.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
